{
  "name": "murderboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview --host 0.0.0.0",
    "start:server": "node dist-server/index.js",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json",
    "docker:build": "./scripts/docker-build.sh",
    "docker:publish": "PUSH=true ./scripts/docker-build.sh"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@clerk/express": "^2.1.16",
    "@clerk/themes": "^2.4.57",
    "@monaco-editor/react": "^4.7.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "mongoose": "^9.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tldraw": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
}
