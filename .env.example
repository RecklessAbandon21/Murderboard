MONGO_URI=mongodb://localhost:27017/murderboard

# Clerk — create a project at https://dashboard.clerk.com, then copy these values
CLERK_SECRET_KEY=sk_test_...

# Frontend (must be prefixed VITE_ to be exposed to the browser)
VITE_API_BASE_URL=
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Build metadata — injected automatically by scripts/docker-build.sh during Docker build.
# Do not set these manually in production; they are supplied as Docker build args.
# Local fallbacks are used in development (version route returns 0.0.0-local / unknown).
APP_VERSION=
GIT_COMMIT_SHA=
GIT_COMMIT_SHORT=
PUBLIC_REPO_URL=
BUILD_TIMESTAMP=
